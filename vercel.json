{
  "version": 2,
  "builds": [
    { "src": "dist/**", "use": "@vercel/static" },
    { "src": "api/**/*.js", "use": "@vercel/node" }
  ],
  "routes": [
   
    { "src": "/api/(.*)", "dest": "/api/$1.js" },

  
    {
      "src": "/assets/(.*)",
      "dest": "/dist/assets/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },

  
    { "src": "/(.*)", "dest": "/dist/index.html" }
  ]
}