# Variables requeridas por scripts/.deploy-ludo-advanced.ps1
# Copia estos nombres al .env de la raiz del proyecto y rellena con tus tokens reales.
# El .env esta gitignoreado - NUNCA commitees tokens.

# Token de Vercel (https://vercel.com/account/tokens)
VC_TOKEN=

# GitHub Personal Access Token con permisos repo (https://github.com/settings/personal-access-tokens)
GITHUB_TOKEN=

# Usuario y repositorio destino para el push de la build
GITHUB_USER=dansanchezh24-ludo
GITHUB_REPO=ludo-lounge

# (Opcional) Nombre de la rama temporal usada para el deploy. Default: deploy-temp
# DEPLOY_BRANCH=deploy-temp
